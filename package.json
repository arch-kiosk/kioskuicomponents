{
  "name": "@arch-kiosk/kioskuicomponents",
  "version": "0.4.3",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./kioskuicomponents.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/kioskuicomponents.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "author": "Lutz Klein",
  "license": "AGPL-3.0",
  "prettier": {
    "semi": true,
    "trailingComma": "all",
    "singleQuote": false,
    "printWidth": 120,
    "tabWidth": 4
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "patch and dist": "vite build && npm version patch && npm pack --pack-destination ./dist",
    "patch and dist Kiosk": "vite build && npm version patch && --mode bundle",
    "preview": "vite preview",
    "test": "vitest --mode development"
  },
  "dependencies": {
    "@arch-kiosk/kiosktsapplib": "^0.3.1",
    "@vaadin/combo-box": "^24.5.5",
    "@vaadin/dialog": "^24.5.5",
    "@vaadin/grid": "^24.5.5",
    "dexie": "^4.0.10",
    "lit": "^3.2.1",
    "openseadragon": "github:arch-kiosk/openseadragon#imagetilesource_with_ajax",
    "rollup-plugin-license": "^3.5.3"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/openseadragon": "^3.0.10",
    "prettier": "^3.4.2",
    "rollup-plugin-copy": "^3.5.0",
    "sass": "^1.77.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-html": "^3.2.2"
  }
}
